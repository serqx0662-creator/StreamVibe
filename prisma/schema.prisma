generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  image         String?
  role          String    @default("USER")
  watchlist     Movie[]
}

model Movie {
  id          String   @id @default(cuid())
  title       String
  category    String
  thumbnail   String
  users       User[]
}